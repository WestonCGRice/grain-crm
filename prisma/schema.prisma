generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Commodity {
  CORN
  SOYBEANS
  RICE
}

enum ContactStatus {
  LEAD
  ACTIVE
  INACTIVE
  CUSTOMER
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  NOTE
}

enum DealStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum InterestLevel {
  LOW
  MEDIUM
  HIGH
}

model Contact {
  id        String        @id @default(cuid())
  firstName String
  lastName  String
  email     String?       @unique
  phone     String?
  company   String?
  title     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  notes     String?
  status    ContactStatus @default(LEAD)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  commodityContacts CommodityContact[]
  interactions      Interaction[]
  deals             Deal[]
}

model CommodityContact {
  id              String        @id @default(cuid())
  contactId       String
  commodity       Commodity
  interestLevel   InterestLevel @default(MEDIUM)
  estimatedVolume Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, commodity])
}

model Interaction {
  id        String          @id @default(cuid())
  contactId String
  type      InteractionType
  date      DateTime        @default(now())
  notes     String?
  createdAt DateTime        @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Deal {
  id             String     @id @default(cuid())
  contactId      String
  commodity      Commodity
  quantity       Decimal    @db.Decimal(12, 2)
  pricePerBushel Decimal    @db.Decimal(10, 4)
  totalValue     Decimal    @db.Decimal(14, 2)
  status         DealStatus @default(PENDING)
  dealDate       DateTime   @default(now())
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
