generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String   @id @default(cuid())
  username              String   @unique
  name                  String?
  email                 String?  @unique
  passwordHash          String
  totpSecret            String?
  totpEnabled           Boolean  @default(false)
  role                  String   @default("MERCHANDISER")
  isAdmin               Boolean  @default(false)
  contractNotifications Boolean  @default(false)
  inviteToken              String?  @unique
  inviteExpires            DateTime?
  mustSetPassword          Boolean  @default(false)
  accessMerchandising      Boolean   @default(true)
  accessAdministration     Boolean   @default(false)
  accessScaleOperations    Boolean   @default(false)
  accessOperationsPlanning Boolean   @default(false)
  failedLoginAttempts      Int       @default(0)
  failedLoginWindowStart   DateTime?
  accountLocked            Boolean   @default(false)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  contractAuditLogs ContractAuditLog[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  city      String?
  state     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealsPickedUp        Deal[]     @relation("PickedUpLocation")
  dealsDeliveredTo     Deal[]     @relation("DeliveredLocation")
  dispatchPickups      Dispatch[] @relation("DispatchPickupLocation")
  dispatchDeliveries   Dispatch[] @relation("DispatchDeliveryLocation")
}

model ScaleTicket {
  id           String    @id @default(cuid())
  ticketNumber String    @unique
  ticketType   String
  ticketDate   DateTime  @default(now())
  cropYear     String?
  commodity    String?
  grossWeight  Decimal?  @db.Decimal(12, 2)
  tareWeight   Decimal?  @db.Decimal(12, 2)
  netWeight    Decimal?  @db.Decimal(12, 2)
  billOfLading String?
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  grades ScaleTicketGrade?
}

model ScaleTicketGrade {
  id            String      @id @default(cuid())
  ticketId      String      @unique
  ticket        ScaleTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  moisture      Decimal?    @db.Decimal(6, 2)
  testWeight    Decimal?    @db.Decimal(6, 2)
  foreignMatter Decimal?    @db.Decimal(6, 2)
  splits        Decimal?    @db.Decimal(6, 2)
  totalDamage   Decimal?    @db.Decimal(6, 2)
  heatDamage    Decimal?    @db.Decimal(6, 2)
  milling       Decimal?    @db.Decimal(6, 2)
  wholeGrain    Decimal?    @db.Decimal(6, 2)
  grade         String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum Commodity {
  CORN
  SOYBEANS
  RICE
}

enum ContactType {
  ORIGINATION
  CUSTOMER
}

enum ContactStatus {
  LEAD
  ACTIVE
  INACTIVE
  CUSTOMER
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  NOTE
}

enum DealStatus {
  PENDING
  COMPLETED
  CANCELLED
  COMPLETED_UNFILLED
  COMPLETED_FILLED
  SETTLED
  DELETED
}

enum InterestLevel {
  LOW
  MEDIUM
  HIGH
}

model Contact {
  id                String        @id @default(cuid())
  farmingEntityName String?
  firstName         String
  lastName          String
  email             String?       @unique
  phone             String?
  company           String?
  title             String?
  address           String?
  city              String?
  state             String?
  zip               String?
  notes             String?
  status            ContactStatus @default(LEAD)
  contactType       ContactType   @default(ORIGINATION)

  // Origination commodity lists
  riceList          Boolean       @default(false)
  cornList          Boolean       @default(false)
  soybeanList       Boolean       @default(false)

  // Sales commodity lists (Grain Customers)
  riceRoughExport   Boolean       @default(false)
  riceRoughDomestic Boolean       @default(false)
  soybeansDomestic  Boolean       @default(false)
  soybeansExport    Boolean       @default(false)
  cornDomestic      Boolean       @default(false)
  cornExport        Boolean       @default(false)

  riceAcres         Decimal?      @db.Decimal(10, 2)
  cornAcres         Decimal?      @db.Decimal(10, 2)
  soybeanAcres      Decimal?      @db.Decimal(10, 2)
  riceEstYield      Decimal?      @db.Decimal(10, 2)
  cornEstYield      Decimal?      @db.Decimal(10, 2)
  soybeanEstYield   Decimal?      @db.Decimal(10, 2)
  smsOptIn          Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  commodityContacts CommodityContact[]
  interactions      Interaction[]
  deals             Deal[]
}

model CommodityContact {
  id              String        @id @default(cuid())
  contactId       String
  commodity       Commodity
  interestLevel   InterestLevel @default(MEDIUM)
  estimatedVolume Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, commodity])
}

model Interaction {
  id        String          @id @default(cuid())
  contactId String
  type      InteractionType
  date      DateTime        @default(now())
  notes     String?
  createdAt DateTime        @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Deal {
  id             String     @id @default(cuid())
  contactId      String
  commodity      Commodity
  quantity       Decimal    @db.Decimal(12, 2)
  pricePerBushel Decimal    @db.Decimal(10, 4)
  basis          Decimal?   @db.Decimal(10, 4)
  totalValue     Decimal    @db.Decimal(14, 2)
  status         DealStatus @default(PENDING)
  contractNumber String?    @unique
  cropYear       String?
  futuresMonth   String?
  futuresYear    String?
  orderEntered   String?
  hedged         String?
  dealDate       DateTime   @default(now())
  notes          String?
  deletedAt      DateTime?
  dealType             String?
  pickedUpLocationId   String?
  deliveredLocationId  String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  contact           Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contractAuditLogs ContractAuditLog[]
  futuresContract   FuturesContract?
  pickedUpLocation  Location?          @relation("PickedUpLocation", fields: [pickedUpLocationId], references: [id])
  deliveredLocation Location?          @relation("DeliveredLocation", fields: [deliveredLocationId], references: [id])
}

model FuturesContract {
  id                String    @id @default(cuid())
  dealId            String    @unique
  deal              Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  commodity         Commodity
  futuresMonth      String
  futuresYear       String
  futuresPrice      Decimal   @db.Decimal(10, 4)
  quantity          Decimal   @db.Decimal(12, 2)
  numberOfContracts Int
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ContractAuditLog {
  id             String   @id @default(cuid())
  dealId         String
  userId         String
  action         String
  fromStatus     String?
  toStatus       String?
  contractNumber String?
  commodity      String?
  contactName    String?
  createdAt      DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

model MessageRecord {
  id             String   @id @default(cuid())
  commodity      String
  messageText    String
  recipientCount Int
  sentAt         DateTime @default(now())
  sentByName     String?
}

model Driver {
  id        String     @id @default(cuid())
  name      String
  phone     String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  dispatches Dispatch[]
}

model Truck {
  id          String     @id @default(cuid())
  number      String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  dispatches Dispatch[]
}

model Dispatch {
  id                 String   @id @default(cuid())
  truckId            String
  driverId           String
  commodity          String
  pickupLocationId   String
  deliveryLocationId String
  startTime          DateTime
  durationMinutes    Int      @default(90)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  truck            Truck    @relation(fields: [truckId], references: [id])
  driver           Driver   @relation(fields: [driverId], references: [id])
  pickupLocation   Location @relation("DispatchPickupLocation", fields: [pickupLocationId], references: [id])
  deliveryLocation Location @relation("DispatchDeliveryLocation", fields: [deliveryLocationId], references: [id])
}
