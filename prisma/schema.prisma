generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String   @id @default(cuid())
  username              String   @unique
  name                  String?
  email                 String?  @unique
  passwordHash          String
  totpSecret            String?
  totpEnabled           Boolean  @default(false)
  isAdmin               Boolean  @default(false)
  contractNotifications Boolean  @default(false)
  inviteToken           String?  @unique
  inviteExpires         DateTime?
  mustSetPassword       Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  contractAuditLogs ContractAuditLog[]
}

enum Commodity {
  CORN
  SOYBEANS
  RICE
}

enum ContactType {
  ORIGINATION
  CUSTOMER
}

enum ContactStatus {
  LEAD
  ACTIVE
  INACTIVE
  CUSTOMER
}

enum InteractionType {
  CALL
  EMAIL
  MEETING
  NOTE
}

enum DealStatus {
  PENDING
  COMPLETED
  CANCELLED
  COMPLETED_UNFILLED
  COMPLETED_FILLED
  SETTLED
  DELETED
}

enum InterestLevel {
  LOW
  MEDIUM
  HIGH
}

model Contact {
  id                String        @id @default(cuid())
  farmingEntityName String?
  firstName         String
  lastName          String
  email             String?       @unique
  phone             String?
  company           String?
  title             String?
  address           String?
  city              String?
  state             String?
  zip               String?
  notes             String?
  status            ContactStatus @default(LEAD)
  contactType       ContactType   @default(ORIGINATION)

  // Origination commodity lists
  riceList          Boolean       @default(false)
  cornList          Boolean       @default(false)
  soybeanList       Boolean       @default(false)

  // Sales commodity lists (Grain Customers)
  riceRoughExport   Boolean       @default(false)
  riceRoughDomestic Boolean       @default(false)
  soybeansDomestic  Boolean       @default(false)
  soybeansExport    Boolean       @default(false)
  cornDomestic      Boolean       @default(false)
  cornExport        Boolean       @default(false)

  riceAcres         Decimal?      @db.Decimal(10, 2)
  cornAcres         Decimal?      @db.Decimal(10, 2)
  soybeanAcres      Decimal?      @db.Decimal(10, 2)
  riceEstYield      Decimal?      @db.Decimal(10, 2)
  cornEstYield      Decimal?      @db.Decimal(10, 2)
  soybeanEstYield   Decimal?      @db.Decimal(10, 2)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  commodityContacts CommodityContact[]
  interactions      Interaction[]
  deals             Deal[]
}

model CommodityContact {
  id              String        @id @default(cuid())
  contactId       String
  commodity       Commodity
  interestLevel   InterestLevel @default(MEDIUM)
  estimatedVolume Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, commodity])
}

model Interaction {
  id        String          @id @default(cuid())
  contactId String
  type      InteractionType
  date      DateTime        @default(now())
  notes     String?
  createdAt DateTime        @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Deal {
  id             String     @id @default(cuid())
  contactId      String
  commodity      Commodity
  quantity       Decimal    @db.Decimal(12, 2)
  pricePerBushel Decimal    @db.Decimal(10, 4)
  basis          Decimal?   @db.Decimal(10, 4)
  totalValue     Decimal    @db.Decimal(14, 2)
  status         DealStatus @default(PENDING)
  contractNumber String?    @unique
  cropYear       String?
  futuresMonth   String?
  futuresYear    String?
  hedged         String?
  dealDate       DateTime   @default(now())
  notes          String?
  deletedAt      DateTime?
  dealType       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  contact           Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contractAuditLogs ContractAuditLog[]
}

model ContractAuditLog {
  id             String   @id @default(cuid())
  dealId         String
  userId         String
  action         String
  fromStatus     String?
  toStatus       String?
  contractNumber String?
  commodity      String?
  contactName    String?
  createdAt      DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}
